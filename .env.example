# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://cardex:password@localhost:5432/cardex?schema=public"

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-to-a-long-random-string-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-to-a-different-long-random-string"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
API_PREFIX="v1"

# ─── Rate limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60          # seconds
THROTTLE_LIMIT=100       # requests per TTL window

# ─── Cloudflare R2 (card images / avatars) ─────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="cardex-assets"
R2_PUBLIC_URL="https://assets.cardex.ar"

# ─── Push notifications ─────────────────────────────────────────────────────────
FCM_SERVER_KEY=""
APNS_KEY_ID=""
APNS_TEAM_ID=""

# ─── Pricing oracle ────────────────────────────────────────────────────────────
BLUE_DOLLAR_API_URL="https://dolarapi.com/v1/dolares/blue"
PRICE_CACHE_TTL_SECONDS=10800     # 3 hours

# ─── Matching ──────────────────────────────────────────────────────────────────
MATCH_RADIUS_METERS=50000
MATCH_SCORE_THRESHOLD=0.55
MAX_NOTIFICATIONS_PER_CYCLE=3

# ─── Trust / guarantees ────────────────────────────────────────────────────────
PRIMERA_OFERTA_RESERVE_USD=20

# ─── Swagger ───────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=true
