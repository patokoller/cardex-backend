{
  "extends": "./tsconfig.json",
  "exclude": ["node_modules", "test", "dist", "prisma", "**/*spec.ts"],
  "compilerOptions": {
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictBindCallApply": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": false,
    "declaration": false,
    "noEmitOnError": false
  }
}
